# Qwen2.5-VL-72B Model Server
# Serves the VLM via vLLM with OpenAI-compatible API
# Deployment: GKE with GPU (NVIDIA L4 × 4)

FROM vllm/vllm-openai:latest

# Model will be downloaded from HuggingFace on first run
# or mounted from GCS via a PVC
ENV MODEL_NAME="Qwen/Qwen2.5-VL-72B-Instruct"
ENV MAX_MODEL_LEN=4096
ENV TENSOR_PARALLEL_SIZE=4
ENV GPU_MEMORY_UTILIZATION=0.9

EXPOSE 8000

ENTRYPOINT ["python3", "-m", "vllm.entrypoints.openai.api_server"]
CMD ["--model", "Qwen/Qwen2.5-VL-72B-Instruct", \
     "--tensor-parallel-size", "4", \
     "--max-model-len", "4096", \
     "--gpu-memory-utilization", "0.9", \
     "--trust-remote-code", \
     "--dtype", "auto", \
     "--host", "0.0.0.0", \
     "--port", "8000"]
